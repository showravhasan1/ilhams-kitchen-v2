generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  
  // Customer details
  name      String
  phone     String
  address   String
  zone      String   // "Dhaka" or "Outside"
  
  // Product details
  item      String   // e.g., "250g", "500g", "1kg", "2kg"
  quantity  Int      @default(1)
  
  // Payment
  subtotal  Int
  shipping  Int
  total     Int
  
  // Status
  status    String   @default("Pending") // Pending, Shipped, Delivered, Cancelled
}
